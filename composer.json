{
    "name": "protonemedia/laravel-xss-protection",
    "description": "Laravel XSS protection, middleware and sanitization",
    "keywords": [
        "protonemedia",
        "laravel",
        "laravel-xss-protection"
    ],
    "homepage": "https://github.com/protonemedia/laravel-xss-protection",
    "license": "MIT",
    "authors": [
        {
            "name": "Pascal Baljet",
            "email": "pascal@protone.media",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2|^8.3|^8.4|^8.5",
        "illuminate/contracts": "^10.48|^11.44|^12.40",
        "spatie/laravel-package-tools": "^1.9.2",
        "voku/anti-xss": "~4.1.42",
        "voku/portable-ascii": "~2.0.0"
    },
    "replace": {
        "voku/portable-utf8": "6.0.99"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^7.0|^8.5",
        "orchestra/testbench": "^8.35|^9.14|^10.5",
        "pestphp/pest": "^2.34|^3.7|^4.0",
        "pestphp/pest-plugin-laravel": "^2.4|^3.1|^4.0",
        "phpunit/phpunit": "^10.4|^11.5.3|^12.0"
    },
    "autoload": {
        "psr-4": {
            "ProtoneMedia\\LaravelXssProtection\\": "src",
            "ProtoneMedia\\LaravelXssProtection\\Database\\Factories\\": "database/factories",
            "voku\\helper\\": "vendor-lib/voku/helper"
        },
        "files": [
            "vendor-lib/voku/bootstrap.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "ProtoneMedia\\LaravelXssProtection\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ProtoneMedia\\LaravelXssProtection\\ServiceProvider"
            ]
        }
    },
    "prefer-stable": true
}
